{
  "patchId": "documentation_api_common_structure",
  "description": "Translate common structure and generated title suffixes across Bitburner API documentation pages while preserving identifiers, links, signatures, and code snippets.",
  "gameVersion": "3.0.1",
  "sourceMapOrigins": [
    "generated API Documenter markdown embedded in main.bundle.js"
  ],
  "scope": "Documentation > Resources > NS/API generated documentation common headings, breadcrumbs, table headers, and page title suffixes",
  "preserveTerms": [
    "bitburner",
    "NS",
    "API",
    "Scripts",
    "RAM",
    "PID",
    "BitNode",
    "Faction",
    "Augmentation",
    "Netscript",
    "JavaScript",
    "TypeScript",
    "React",
    "method/property/interface/type identifiers",
    "function names",
    "file names",
    "code snippets"
  ],
  "operations": [
    {
      "type": "regexReplace",
      "file": "resources/app/dist/main.bundle.js",
      "id": "api_title_property_suffix",
      "pattern": "## ([^\\\\]+?) property\\\\n\\\\n",
      "replacement": "## $1 속성\\n\\n",
      "targetPattern": "## ([^\\\\]+?) 속성\\\\n\\\\n",
      "expectedCount": 705,
      "allowRemainingSource": false,
      "allowExistingTarget": true
    },
    {
      "type": "regexReplace",
      "file": "resources/app/dist/main.bundle.js",
      "id": "api_title_type_suffix",
      "pattern": "## ([^\\\\]+?) type\\\\n\\\\n",
      "replacement": "## $1 타입\\n\\n",
      "targetPattern": "## ([^\\\\]+?) 타입\\\\n\\\\n",
      "expectedCount": 80,
      "allowRemainingSource": false,
      "allowExistingTarget": true
    },
    {
      "type": "regexReplace",
      "file": "resources/app/dist/main.bundle.js",
      "id": "api_title_interface_suffix",
      "pattern": "## ([^\\\\]+?) interface\\\\n\\\\n",
      "replacement": "## $1 인터페이스\\n\\n",
      "targetPattern": "## ([^\\\\]+?) 인터페이스\\\\n\\\\n",
      "expectedCount": 140,
      "allowRemainingSource": false,
      "allowExistingTarget": true
    },
    {
      "type": "regexReplace",
      "file": "resources/app/dist/main.bundle.js",
      "id": "api_title_method_suffix",
      "pattern": "## ([^\\\\]+?) method\\\\n\\\\n",
      "replacement": "## $1 메서드\\n\\n",
      "targetPattern": "## ([^\\\\]+?) 메서드\\\\n\\\\n",
      "expectedCount": 536,
      "allowRemainingSource": false,
      "allowExistingTarget": true
    },
    {
