      "file": "resources/app/dist/main.bundle.js",
      "id": "api_breadcrumb_home",
      "source": "[Home](./index.md)",
      "target": "[홈](./index.md)",
      "expectedCount": 1533,
      "allowRemainingSource": false,
      "allowExistingTarget": true
